# ── Required in production ────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-64-char-string

# PostgreSQL connection string (Render / Neon / Supabase)
# Leave blank to use local SQLite for development
DATABASE_URL=postgresql://user:password@host:5432/tracksuite

# Comma-separated list of allowed frontend origins
# No trailing slash, no wildcard in production
ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:5173

# ── Optional ─────────────────────────────────────────────────────────────────
# Environment tag shown in logs
ENVIRONMENT=production
